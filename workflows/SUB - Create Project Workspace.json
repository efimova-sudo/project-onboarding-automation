    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nconst state = $('Set/Edit: Get State').first().json.state;\nconst projectFolder = $('HTTP: Drive - Create Project Folder').first().json;\n\nconst subfolders = items.map(item => ({\n  id: item.json.id,\n  name: item.json.name,\n}));\n\nconst subfolderByName = Object.fromEntries(\n  subfolders.map(folder => [folder.name, folder.id])\n);\n\nconst requiredSubfolders = [\n  'Contract and Change Orders',\n  'Finish Material',\n  'Inspirations',\n  'Invoices',\n  'Plans and Reports',\n  'Media',\n];\n\nconst missingSubfolders = requiredSubfolders.filter(name => !subfolderByName[name]);\n\nif (missingSubfolders.length > 0) {\n  throw new Error(\n    'Missing subfolders: ' + missingSubfolders.join(', ') + '. Created: ' +\n    subfolders.map(f => f.name).join(', ')\n  );\n}\n\nreturn [{\n  json: {\n    state,\n    workspace: {\n      folder_id: projectFolder.id,\n      folder_name: projectFolder.name,\n      subfolders,\n      subfolder_ids: {\n        contracts: subfolderByName['Contract and Change Orders'],\n        finish_material: subfolderByName['Finish Material'],\n        inspirations: subfolderByName['Inspirations'],\n        invoices: subfolderByName['Invoices'],\n        plans_reports: subfolderByName['Plans and Reports'],\n        media: subfolderByName['Media'],\n      },\n    },\n  },\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1280,
        224
      ],
      "id": "9e0a6533-2d8f-4e0c-9dbb-3ae9e7d84976",
