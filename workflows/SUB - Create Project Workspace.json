    {
      "parameters": {
        "jsCode": "const inp = $input.first().json;\nconst subfolders = [\n  'Contract and Change Orders',\n  'Finish Material',\n  'Inspirations',\n  'Invoices',\n  'Plans and Reports',\n  'Media',\n];\n// inp is the Drive Create Folder response: { id, name, mimeType }\n// Spread it so each batch item carries the folder id, then add subfolder_name\nreturn subfolders.map(name => ({ json: { ...inp, subfolder_name: name } }));"
      },
      "id": "1578320b-636f-4c51-9352-bf8c92d6a0e6",
      "name": "Code: Prepare Subfolder Items",
      "type": "n8n-nodes-base.code",
