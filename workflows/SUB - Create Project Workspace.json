        "nodeCredentialType": "googleDriveOAuth2Api",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"name\": \"{{ $json.subfolder_name }}\", \"mimeType\": \"application/vnd.google-apps.folder\", \"parents\": [\"{{ $json.id }}\"] }",
        "options": {}
